# Se Mod
set $mod Mod4

# Set Colours
set $bg-color            #000000
set $inactive-bg-color   #000000
set $text-color          #f3f4f5
set $inactive-text-color #676E7D
set $urgent-bg-color     #E53935

# Set Font
font pango:Hack Nerd Font,12

# Floating Mod
floating_modifier $mod

gaps inner 5
include /etc/sway/config.d/*

#############
# WORKSPACE #
#############

set $monitorMain DP-6
set $monitorLap eDP-1

set $ws1 "1:一"
set $ws2 "2:二"
set $ws3 "3:三"
set $ws4 "4:四"
set $ws5 "5:五"
set $ws6 "6:六"
set $ws7 "7:七"
set $ws8 "8:八"
set $ws9 "9:九"
set $ws10 "10:十"

workspace $ws1 output $monitorMain
workspace $ws3 output $monitorMain
workspace $ws7 output $monitorMain
workspace $ws10 output $monitorMain
workspace $ws2 output $monitorSide
workspace $ws8 output $monitorLap

# Program on specific workspaces (xprop command)
assign [class="krita"] $ws7
assign [class="Slack"] $ws8
assign [class="discord"] $ws8
assign [class="steam"] $ws9
assign [class="Lutris"] $ws9

#####################
# WINDOW APPEARANCE #
#####################

# Hide Thin Borders
hide_edge_borders none
default_border none
titlebar_border_thickness 0
titlebar_padding 0

client.focused			$bg-color			$bg-color			$text-color				$bg-color
client.unfocused		$inactive-bg-color	$inactive-bg-color	$inactive-text-color	$bg-color
client.focused_inactive	$inactive-bg-color	$inactive-bg-color	$inactive-text-color	$bg-color
client.urgent			$urgent-bg-color	$urgent-bg-color	$text-color				$bg-color

################
# KEY BINDINGS #
################

bindsym $mod+Return exec kitty
bindsym $mod+Shift+space floating toggle
bindsym $mod+t focus mode_toggle
bindsym $mod+d exec rofi -run-list-command "$HOME/.config/rofi/rofi-list $HOME/.bin" -run-command "/bin/bash -i -c '{cmd}'" -rnow -show run 
bindsym $mod+c exec rofi -show calc -modi calc -no-show-match -no-sort
bindsym $mod+v exec rofi -modi clipboard:$HOME/.config/sway/cliphist-rofi-img -show clipboard -show-icons -theme-str '#element-icon {size: 64px; }'
bindsym $mod+Shift+v exec cliphist wipe && wl-copy --clear && notify-send "Clipboard cleared!"

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+q kill
bindsym $mod+f fullscreen toggle
bindsym $mod+a focus parent

# Mode Binding
bindsym $mod+Shift+e mode "quit"

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# resize window
bindsym $mod+Mod1+h resize shrink width 10 px or 10 ppt
bindsym $mod+Mod1+j resize grow height 10 px or 10 ppt
bindsym $mod+Mod1+k resize shrink height 10 px or 10 ppt
bindsym $mod+Mod1+l resize grow width 10 px or 10 ppt

# layout
bindsym $mod+b split v
bindsym $mod+e layout toggle split
# bindsym $mod+b split h
# bindsym $mod+s layout stacking
# bindsym $mod+w layout tabbed

# switch to workspace
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9
bindsym $mod+Shift+0 move container to workspace $ws10

# Pulse Audio controls
bindsym Shift+F12 exec amixer -q -D pulse sset Master 5%+ && pkill -RTMIN+1 swaybar
bindsym XF86AudioRaiseVolume exec amixer -q -D pulse sset Master 5%+ && pkill -RTMIN+1 swaybar

bindsym Shift+F11 exec amixer -q -D pulse sset Master 5%- && pkill -RTMIN+1 swaybar
bindsym XF86AudioLowerVolume exec amixer -q -D pulse sset Master 5%- && pkill -RTMIN+1 swaybar

bindsym Shift+F10 exec amixer -q -D pulse sset Master toggle && pkill -RTMIN+1 swaybar
bindsym XF86AudioMute exec amixer -q -D pulse sset Master toggle && pkill -RTMIN+1 swaybar

bindsym Shift+F9 exec amixer set Capture toggle && pkill -RTMIN+1 swaybar
bindsym Ctrl+Shift+X exec amixer set Capture toggle && pkill -RTMIN+1 swaybar

bindsym XF86AudioPlay exec mpc toggle -q && pkill -RTMIN+1 swaybar

# Sreen brightness controls
bindsym XF86MonBrightnessUp exec brightnessctl s 20%+
bindsym XF86MonBrightnessDown exec brightnessctl s 20%-

# Extra Keys / Shortcuts
bindsym XF86Sleep exec systemctl suspend
bindsym $mod+Ctrl+Shift+x exec systemctl suspend
bindsym $mod+Shift+x exec loginctl lock-session

bindsym Print exec python $HOME/Documents/VRCProjects/VRCControls/screenshot.py -r
bindsym XF86Calculator exec python $HOME/Documents/VRCProjects/VRCControls/screenshot.py -r

bindsym Ctrl+space exec dunstctl close
bindsym Ctrl+Shift+space exec dunstctl close-all

bar {
    modifier $mod
	tray_output primary
    swaybar_command waybar
}

input "type:keyboard" {
    xkb_options caps:escape
}

input "type:touchpad" {
    dwt enabled
    dwtp enabled
    tap enabled
    natural_scroll enabled
    tap_button_map lrm
}

mode "quit" {
	bindsym $mod+Shift+e exit

	bindsym Return mode "default"
	bindsym Escape mode "default"
}

output * bg ~/.wallpaper.png fill
output $monitorLap resolution 3456x2160 position 2560,0 scale 2
output $monitorMain resolution 2560x1440 position 0,0
bindsym Alt+Shift+D exec swaymsg 'output $monitorLap resolution 3456x2160 position "0,0" scale 1'

input type:tablet_pad map_to_output $monitorMain
input type:tablet_pad left_handed 1
input type:tablet_tool map_to_output $monitorMain
input type:tablet_tool left_handed 1

exec --no-startup-id gammastep
exec --no-startup-id fcitx5
exec --no-startup-id dropbox
exec --no-startup-id dunst

exec "~/.bin/auto_exit_fullscreen.sh"
exec swayidle -w \
         timeout 600 'swaylock -f -C ~/.config/sway/lock-config-matugen' \
         before-sleep 'swaylock -f -C ~/.config/sway/lock-config-matugen' \
         lock 'swaylock -f -C ~/.config/sway/lock-config-matugen'

seat seat0 hide_cursor 5000

# exec --no-startup-id /usr/lib/xdg-desktop-portal-wlr
# exec --no-startup-id /usr/lib/xdg-desktop-portal -r
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1

exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store
